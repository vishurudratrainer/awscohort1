# Create an AWS EC2 Instance
resource "aws_instance" "my_first_server1" {
  ami           = "ami-0c7217cdde317cfec" # Ubuntu 22.04 LTS AMI ID for us-east-1
  instance_type = "t2.micro"             # Free-tier eligible size

  tags = {
    Name = "Terraform-EC2-Example1"
    Env  = "Dev"
  }
}

resource "aws_instance" "my_first_server2" {
  ami           = "ami-0c7217cdde317cfec" # Ubuntu 22.04 LTS AMI ID for us-east-1
  instance_type = "t2.micro"             # Free-tier eligible size

  tags = {
    Name = "Terraform-EC2-Example2"
    Env  = "Dev"
  }
}